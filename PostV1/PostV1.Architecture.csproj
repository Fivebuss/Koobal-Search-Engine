<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net472</TargetFramework>
    <LangVersion>latest</LangVersion>
    <AssemblyName>PartSearchSuggest.PostV1.Architecture</AssemblyName>
    <RootNamespace>PartSearchSuggest</RootNamespace>
    <OutputPath>bin\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <IsPackable>false</IsPackable>
    <!-- Compile-check only — must NEVER deploy to GameData / Main / ModTest. -->
    <PostV1ArchitectureOnly>true</PostV1ArchitectureOnly>
  </PropertyGroup>

  <!--
    SDK default globs pick up all PostV1/**/*.cs under this folder.
    No KSP / Unity / Harmony references on purpose.
    Live adapters at wire-up will live in the shipping csproj once Compile Remove is lifted.
    Unwired* UI ports throw NotImplementedException at the boundary; Recording* doubles
    exercise navigator/apply algorithms without EditorLogic.
  -->
</Project>
